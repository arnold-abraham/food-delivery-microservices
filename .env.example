# Copy this file to .env and fill in real values before starting the stack.
# .env is git-ignored; .env.example is the template committed to the repo.

# HS256 signing key shared by user-service and api-gateway.
# Must be a Base64-encoded value with at least 256 bits of entropy (32 raw bytes).
# Generate: openssl rand -base64 48
JWT_SECRET=REPLACE_WITH_STRONG_SECRET

# Optional — defaults shown below; override as needed.
# JWT_TTL_SECONDS=3600
# DB_USER=food
# DB_PASSWORD=food